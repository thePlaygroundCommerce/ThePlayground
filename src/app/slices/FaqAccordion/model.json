{
  "type": "SharedSlice",
  "id": "faq_accordion",
  "name": "FaqAccordion",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "description": "Standard FAQ accordion with a section title, description, and collapsible items for each question and answer.",
      "version": "initial",
      "imageUrl": "",
      "docURL": "...",
      "primary": {
        "title": {
          "type": "StructuredText",
          "config": {
            "single": "heading2",
            "label": "Section Title"
          }
        },
        "description": {
          "type": "StructuredText",
          "config": {
            "multi": "paragraph,strong,em,hyperlink",
            "label": "Section Intro"
          }
        },
        "faq_items": {
          "type": "Group",
          "config": {
            "label": "Questions",
            "fields": {
              "question": {
                "type": "Text",
                "config": {
                  "label": "Question"
                }
              },
              "answer": {
                "type": "StructuredText",
                "config": {
                  "multi": "paragraph,strong,em,hyperlink",
                  "label": "Answer"
                }
              }
            }
          }
        }
      }
    }
  ]
}
